{
  "name": "shadowrecon-ultimate",
  "version": "2.1.0",
  "description": "World's most powerful all-in-one security testing, network recon & traffic analyst desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "Sayidilxs",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "jws": "^4.0.0"
  },
  "build": {
    "appId": "com.sayidilxs.shadowrecon",
    "productName": "ShadowRecon Ultimate",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
